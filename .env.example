# Anima 环境变量示例
# 复制为 .env 并填写真实值

# ── AI Provider ───────────────────────────────────────────────
# OpenAI API Key（必填）
OPENAI_API_KEY=sk-...

# ── 数据目录 ──────────────────────────────────────────────────
# DATA_DIR=data

# ── Telegram（可选）────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# ── Discord（可选）─────────────────────────────────────────────
# 创建 Bot: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_OWNER_USER_ID=
# 限定 Guild（留空则响应所有服务器）
DISCORD_GUILD_ID=

# ── Slack（可选）───────────────────────────────────────────────
# 创建 App: https://api.slack.com/apps
# 需要的 Scopes: chat:write, app_mentions:read, im:history, im:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_OWNER_USER_ID=

# ── Web API 认证（可选）────────────────────────────────────────
# 设置后所有 /api/* 和 /ws 请求需要 Bearer Token 认证
# 留空则不启用认证（适合纯本地使用）
ANIMA_API_TOKEN=

# ── Email 工具（可选）──────────────────────────────────────────
ANIMA_SMTP_HOST=smtp.gmail.com
ANIMA_SMTP_PORT=587
ANIMA_SMTP_USER=your@email.com
ANIMA_SMTP_PASSWORD=
ANIMA_IMAP_HOST=imap.gmail.com
ANIMA_IMAP_PORT=993
