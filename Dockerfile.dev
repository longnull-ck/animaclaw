# ============================================================
# Anima — 开发环境 Dockerfile
# 支持热重载，代码通过 volume 挂载
# 用法: docker compose -f docker-compose.dev.yml up
# ============================================================

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 安装依赖
COPY pyproject.toml ./
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e ".[all]" && \
    pip install --no-cache-dir watchfiles

ENV PYTHONUNBUFFERED=1 \
    ANIMA_DATA_DIR=/app/data

EXPOSE 3210

# 开发模式：使用 watchfiles 自动重启
CMD ["watchfiles", "--filter", "python", "python run.py start", "./anima"]
